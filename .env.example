# Optional local overrides only.
# Normal Cowork/git-clone usage does not require a .env file.
# Public Azure Application values are read from hare.config.json.

# OMH_M365_CLIENT_ID=00000000-0000-0000-0000-000000000000
# OMH_M365_TENANT_ID=00000000-0000-0000-0000-000000000000

# Optional.
# OMH_M365_POLICY_PATH=policy.json
# HARE_M365_DATA_DIR=/path/to/shared/hare-data
