# Copy this file to .env and fill values from the approved Azure Application.
# Do not commit real tenant IDs, client IDs, tokens, or cache files.

OMH_M365_CLIENT_ID=00000000-0000-0000-0000-000000000000
OMH_M365_TENANT_ID=00000000-0000-0000-0000-000000000000

# Optional. Defaults are local POC folders.
OMH_M365_POLICY_PATH=policy.json
OMH_M365_DOWNLOAD_DIR=downloads
OMH_M365_CACHE_DIR=.cache
