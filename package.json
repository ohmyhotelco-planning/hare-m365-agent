{
  "name": "@ohmyhotel/hare-m365-agent",
  "version": "0.1.6",
  "private": false,
  "description": "Hare CLI for LLM-driven Microsoft 365 Graph access using delegated permissions.",
  "type": "module",
  "bin": {
    "hare-m365": "dist/cli.js",
    "omh-m365": "dist/cli.js"
  },
  "files": [
    "dist/",
    "hare.config.json",
    "policy.json",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
